[user]
	name = Adrian Obelmejias 
	email = obeladrian@gmail.com

[core]
	editor = nvim
	autocrlf = input

[init]
	defaultBranch = main

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[alias]
	st = status
	co = checkout
	br = branch
	ci = commit
	lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
	last = log -1 HEAD
	unstage = reset HEAD --
	amend = commit --amend
	undo = reset --soft HEAD~1

[diff]
	colorMoved = zebra

[merge]
	conflictstyle = diff3

# Include local config for machine-specific settings
# Create ~/.gitconfig.local for:
# - Work email overrides
# - GPG signing keys
# - Machine-specific aliases
[include]
	path = ~/.gitconfig.local
